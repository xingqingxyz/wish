{
  "tasks": [
    {
      "args": [
        "/Zi",
        "/EHsc",
        "/nologo",
        "/D_DEBUG",
        "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
        "${file}",
        "/utf-8"
      ],
      "command": "cl.exe",
      "detail": "调试器生成的任务。",
      "group": {
        "isDefault": false,
        "kind": "build"
      },
      "label": "C/C++: cl.exe 生成活动文件",
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$msCompile"],
      "type": "cppbuild"
    },
    {
      "type": "cppbuild",
      "label": "C/C++: gcc 生成活动文件",
      "command": "/usr/bin/gcc",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "调试器生成的任务。"
    },
    {
      "label": "Serve Rust Training",
      "type": "shell",
      "command": ["cargo", "xtask", "serve"],
      "options": { "cwd": "${workspaceFolder}/../RustTraining" }
    }
  ],
  "version": "2.0.0"
}
