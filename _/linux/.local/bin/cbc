#!/bin/bash
name=${0##*/}
args=("$@")
while [ $# -ne 0 ]; do
  case "$1" in
    -p | --prompt)
      case "$name" in
        cbc | codebuddy) args+=('-y') ;;
        *) args+=('--yolo') ;;
      esac
      exec -a "$name" glow < <("$(pnpm bin -g)/$name" "${args[@]}")
      ;;
    *) ;;
  esac
  shift
done
exec -a "$name" "$(pnpm bin -g)/$name" "${args[@]}"
